# Network Monitor — Environment Variables
# Copy this file to .env and fill in your values

# Server settings
NETMON_PORT=8765

# Authentication
NETMON_USER=admin
NETMON_PASS=admin

# Database path (default: monitor.db in working directory)
# DB_PATH=./monitor.db

# Monitoring interval in seconds
# CHECK_INTERVAL=20

# ── Email Alerting ──
# SMTP settings for alert emails
# NETMON_SMTP_HOST=smtp.gmail.com
# NETMON_SMTP_PORT=587
# NETMON_SMTP_USER=your@email.com
# NETMON_SMTP_PASS=your_app_password
# NETMON_ALERT_EMAIL=recipient@email.com

# For Gmail: use App Password (https://myaccount.google.com/app-passwords)
# For Outlook: smtp.office365.com, port 587
# For 163.com: smtp.163.com, port 465 (use authorization code)
