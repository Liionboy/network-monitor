# Network Monitor — Environment Variables
# Copy this file to .env and fill in your values
#
#   cp .env.example .env
#   nano .env

# ── Server ──
NETMON_PORT=8765

# ── Authentication ──
NETMON_USER=admin
NETMON_PASS=netmon2026

# ── Monitoring ──
# Check interval in seconds (default: 20)
# CHECK_INTERVAL=20

# ── Email Alerting (optional) ──
# SMTP settings for alert emails.
# Create alert rules in the Alerts tab first, then fill these in.
# NETMON_SMTP_HOST=smtp.gmail.com
# NETMON_SMTP_PORT=587
# NETMON_SMTP_USER=your@email.com
# NETMON_SMTP_PASS=your_app_password
# NETMON_ALERT_EMAIL=recipient@email.com
#
# Gmail:    smtp.gmail.com, port 587 — use App Password (https://myaccount.google.com/apppasswords)
# Outlook:  smtp.office365.com, port 587
# 163.com:  smtp.163.com, port 465 — use authorization code
