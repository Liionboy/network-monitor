# Network Monitor Environment Variables
# Copy this file to .env and fill in your values

# Server settings
NETMON_PORT=8765

# Authentication
NETMON_USER=admin
NETMON_PASS=change_me_to_something_secure

# Database path (default: monitor.db in working directory)
# DB_PATH=./monitor.db

# Monitoring interval in seconds
# CHECK_INTERVAL=20
